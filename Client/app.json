{
  "expo": {
    "name": "발표 피드백",
    "slug": "presentation-feedback",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "presentation-feedback",
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        { "microphonePermission": "발표 녹음을 위해 마이크 접근이 필요합니다." }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
